VITE_API_URL=http://localhost:3000/api/v1
VITE_SOCKET_URL=http://localhost:3000

# Social OAuth — replace with your real keys
# Get Google Client ID from: https://console.cloud.google.com/ → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE.apps.googleusercontent.com

# Get Facebook App ID from: https://developers.facebook.com/ → My Apps
VITE_FACEBOOK_APP_ID=YOUR_FACEBOOK_APP_ID

# Razorpay public key (test or live)
VITE_RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_HERE
